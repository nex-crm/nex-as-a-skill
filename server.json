{
  "$schema": "https://registry.modelcontextprotocol.io/schemas/server.json",
  "name": "ai.nex/nex",
  "displayName": "Nex — Organizational Context & Memory",
  "description": "Connect your email, CRM, Slack, meetings, and 100+ tools into one knowledge graph. Give any AI agent persistent organizational memory across sessions.",
  "version": "1.0.0",
  "publisher": {
    "name": "Nex AI",
    "url": "https://nex.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nex-crm/nex-as-a-skill"
  },
  "homepage": "https://nex.ai",
  "license": "MIT",
  "runtime": "node",
  "install": {
    "npm": {
      "package": "@nex-ai/nex",
      "command": "npx -y @nex-ai/nex"
    }
  },
  "auth": {
    "type": "api_key",
    "env_var": "NEX_API_KEY",
    "instructions": "Sign up at https://nex.ai to get your API key, or start the server without a key and use the 'register' tool."
  },
  "categories": [
    "memory",
    "knowledge-management",
    "crm",
    "integrations",
    "productivity"
  ],
  "tags": [
    "organizational-memory",
    "knowledge-graph",
    "crm",
    "email",
    "slack",
    "meetings",
    "ai-agent",
    "context",
    "persistent-memory"
  ],
