    "nex": "bin/nex.js",
    "nex-mcp": "bin/nex-mcp.js"
  },
  "files": [
    "bin",
    "plugin-commands",
    "platform-rules",
    "platform-plugins",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "ai-memory",
    "knowledge-graph",
    "context",
    "nex",
    "organizational-memory",
    "agent-memory",
    "claude",
    "cursor",
    "copilot",
    "integrations"
  ],
  "scripts": {
    "test": "node --check bin/nex.js && node --check bin/nex-mcp.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nex-crm/nex-as-a-skill.git"
  },
  "homepage": "https://nex.ai",
